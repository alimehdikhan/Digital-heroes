# ==============================================================
# DIGITAL HEROES - ENVIRONMENT VARIABLES
# ==============================================================
# Copy this file to .env.local and populate the values below.
# ==============================================================

# 1. Supabase Configuration
# Found in Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key for Admin Actions (DO NOT EXPOSE TO CLIENT)
# Found in Supabase Dashboard -> Project Settings -> API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 2. Stripe Configuration
# Found in Stripe Dashboard -> Developers -> API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook Secret for testing locally or in production
# Found in Stripe Dashboard -> Developers -> Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# 3. Application Configuration
# The domain the application is hosted on (used for SEO and callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
